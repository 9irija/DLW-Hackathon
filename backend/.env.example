OPENAI_API_KEY=your-openai-api-key-here
PORT=3001
DB_PATH=./data/audit.db
LOG_LEVEL=info

# Agents — defaults: Codex (Responses API). Reasoner (formerly Builder) & Attacker static = gpt-5-codex; Factchecker = gpt-5-codex; Attacker PoC = gpt-5.1-codex-mini.
# To use Chat Completions instead (e.g. if no Codex access), set:
# REASONER_MODEL=gpt-4o    # or BUILDER_MODEL for backwards-compatibility
# FACTCHECKER_MODEL=gpt-4o-mini
# ATTACKER_MODEL=gpt-4o
# ATTACKER_POC_MODEL=gpt-4o-mini
