OPENAI_API_KEY=your-openai-api-key-here
PORT=3001
DB_PATH=./data/audit.db
LOG_LEVEL=info

# Agents — Codex used where helpful (builder, factchecker, attacker). Skeptic has no LLM.
# Defaults: builder/attacker static = gpt-5-codex; factchecker = gpt-5-codex; attacker PoC = gpt-5.1-codex-mini.
# Override to fall back to non-Codex (e.g. if your account has no Codex): BUILDER_MODEL=gpt-4o, etc.
# CODEX_MODEL=gpt-5-codex
# BUILDER_MODEL=gpt-4o
# FACTCHECKER_MODEL=gpt-4o-mini
# ATTACKER_MODEL=gpt-4o
# ATTACKER_POC_MODEL=gpt-4o-mini
