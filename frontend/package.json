{
  "name": "code-review-extension",
  "displayName": "Multi-Agent Code Review",
  "description": "AI-powered multi-agent code review using OpenAI",
  "version": "0.0.1",
  "publisher": "your-publisher-name",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Linters", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      { "command": "codeReview.reviewFile",      "title": "Review Current File",        "category": "Code Review" },
      { "command": "codeReview.reviewSelection", "title": "Review Selection",            "category": "Code Review" },
      { "command": "codeReview.reviewWithDocs",  "title": "Review File with Docs",       "category": "Code Review" },
      { "command": "codeReview.showFindings",    "title": "Show Findings",               "category": "Code Review" },
      { "command": "codeReview.showCharts",      "title": "Show Skeptic Charts",         "category": "Code Review" }
    ],
    "viewsContainers": {
      "activitybar": [{ "id": "codeReview", "title": "Code Review", "icon": "$(shield)" }]
    },
    "views": {
      "codeReview": [
        { "id": "codeReview.agentStatus", "name": "Agent Status" },
        { "id": "codeReview.findings",    "name": "Findings"      },
        { "id": "codeReview.verdict",     "name": "Verdict"       }
      ]
    },
    "configuration": {
      "title": "Multi-Agent Code Review",
      "properties": {
        "codeReview.backendUrl": {
          "type": "string",
          "default": "http://localhost:3001",
          "description": "URL of the code review backend server"
        },
        "codeReview.autoReviewOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically trigger a review when a file is saved"
        }
      }
    },
    "menus": {
      "editor/context": [
        { "command": "codeReview.reviewFile",      "group": "codeReview" },
        { "command": "codeReview.reviewSelection", "group": "codeReview", "when": "editorHasSelection" },
        { "command": "codeReview.reviewWithDocs",  "group": "codeReview" }
      ]
    }
  },
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.24.0"
  }
}
