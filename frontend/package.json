{
  "name": "runchecks",
  "displayName": "RunChecks",
  "description": "AI-powered multi-agent code review — human-gated HITL pipeline",
  "version": "0.1.0",
  "publisher": "your-publisher-name",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Linters", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "runchecks.startReview", "title": "🔍 Run RunChecks Review", "category": "RunChecks" },
      { "command": "runchecks.openSetup",   "title": "Setup & Documents",        "category": "RunChecks" },
      { "command": "runchecks.showStatus",  "title": "Show Agent Pipeline",      "category": "RunChecks" },
      { "command": "codeReview.reviewFile",      "title": "Review Current File",  "category": "Code Review" },
      { "command": "codeReview.reviewSelection", "title": "Review Selection",     "category": "Code Review" },
      { "command": "codeReview.reviewWithDocs",  "title": "Review File with Docs","category": "Code Review" },
      { "command": "codeReview.showFindings",    "title": "Show Findings",        "category": "Code Review" },
      { "command": "codeReview.showCharts",      "title": "Show Skeptic Charts",  "category": "Code Review" }
    ],
    "viewsContainers": {
      "activitybar": [{ "id": "runchecks", "title": "RunChecks", "icon": "media/icon.svg" }]
    },
    "views": {
      "runchecks": [
        { "type": "webview", "id": "runchecks.agentStatus", "name": "Agent Pipeline" }
      ]
    },
    "configuration": {
      "title": "RunChecks",
      "properties": {
        "runchecks.backendUrl": {
          "type": "string",
          "default": "http://127.0.0.1:3001",
          "description": "RunChecks backend URL. Use 127.0.0.1 (not localhost) on Windows."
        },
        "codeReview.backendUrl": {
          "type": "string",
          "default": "http://127.0.0.1:3001",
          "description": "Backend URL (legacy setting, kept for compatibility)."
        },
        "codeReview.autoReviewOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Auto-review on file save (single-shot, no checkpoints)"
        }
      }
    },
    "menus": {
      "editor/context": [
        { "command": "runchecks.startReview",      "group": "runchecks" },
        { "command": "codeReview.reviewFile",      "group": "codeReview" },
        { "command": "codeReview.reviewSelection", "group": "codeReview", "when": "editorHasSelection" },
        { "command": "codeReview.reviewWithDocs",  "group": "codeReview" }
      ]
    }
  },
  "scripts": {
    "compile": "webpack",
    "watch":   "webpack --watch",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node":    "^20.0.0",
    "@types/vscode":  "^1.85.0",
    "@vscode/vsce":   "^2.24.0",
    "ts-loader":      "^9.5.0",
    "typescript":     "^5.3.0",
    "webpack":        "^5.89.0",
    "webpack-cli":    "^5.1.0"
  }
}
